import os
import pandas as pd
import numpy
import scipy.io

def get_sots_all(df, run_n):

    # create column names as needed for the multiple conditions file for SPM
    names = ['OwnCue','OwnElaborate', 'OwnRating','OtherCue','OtherElaborate','OtherRating','GroundCueOnset']
    names = numpy.asarray(names, dtype=object)

    # these are columns we want
    cols = ['TimeAtStartOfTrial','ElaborateCueOnset','RatingOnset']
    duration_cols = ['CueDuration', 'ElaborateCueDuration', 'RatingDuration']
    onsets = []
    durations = []

    # this function does one run per pass, for both own and other trials
    own_df = df.loc[(df.IsOwn == 1)]
    own_df = own_df.loc[(own_df.Run == run_n)]
    own_df.reset_index(inplace=True, drop=True)
    for i in range(len(cols)):
        col = cols[i]
        duration = duration_cols[i]
        array = numpy.asarray(own_df[col].tolist())
        onsets.append(array)
        if col == 'TimeAtStartOfTrial':
            durations.append([float(0)] * len(own_df[col]))
        else:
            durations.append(own_df[duration].tolist())
    
    other_df = df.loc[(df.IsOwn == 0)]
    other_df = other_df.loc[(other_df.Run == run_n)]
    other_df.reset_index(inplace=True, drop=True)
    for i in range(len(cols)):
        col = cols[i]
        duration = duration_cols[i]
        array = numpy.asarray(other_df[col].tolist())
        onsets.append(array)
        if col == 'TimeAtStartOfTrial':
            durations.append([float(0)] * len(other_df[col]))
        else:
            durations.append(other_df[duration].tolist())

    # since we set 'Not Used' to -1 earlier now we need to drop all the values which are -1/1000
    ground_df = df.loc[(df.Run == run_n)]
    ground_df = ground_df.loc[ground_df.GroundCueOnset != -1/1000]
    ground_array = numpy.asarray(ground_df['GroundCueOnset'].tolist())
    ground_durs = numpy.asarray(ground_df['GroundCueDuration'].tolist())
    onsets.append(ground_array)
    durations.append(ground_durs)
    
    # Extract ratings based on conditions (specific to pmod analysis)
    own_ratings = df.loc[(df.IsOwn == 1) & (df.GroundCueResponse == 'Not Used'), 'Rating'].tolist()
    other_ratings = df.loc[(df.IsOwn == 0) & (df.GroundCueResponse == 'Not Used'), 'Rating'].tolist()
    
    pmod = {
        'OwnRating': own_ratings,  # Parametric modulator for Own condition
        'OtherRating': other_ratings  # Parametric modulator for Other condition
    }
    
    run_dict = {
    'names': names,
    'onsets': onsets,
    'durations': durations,
    'pmod': pmod  # Add pmod dictionary to the output
    }

    return run_dict

#loops through each directory in L2_OnsDur
for root, dirs, files in os.walk('data/T2_task_files/L2_OnsDur'):
    
    for d in dirs:

        # Initialize variables to None
        run1, run2, run3 = None, None, None

        #looping through each file in each directory
        for f in os.listdir('data/T2_task_files/L2_OnsDur/' + d):
        
            # does this work automatically?? "(here you should insert the filepaths of interest for your subject)""

            print('data/T2_task_files/L2_OnsDur/' + d + '/' + f)
            
            if 'run1' in f: #needs to be changed to 'Rpt1' in f for M? N? run1 for L
                run1 = pd.read_csv('data/T2_task_files/L2_OnsDur/' + d + '/' + f)
            elif 'run2' in f:
                run2 = pd.read_csv('data/T2_task_files/L2_OnsDur/' + d + '/' + f)
        
        # Filter out non-trial rows for each run if they exist
        if run1 is not None:
                run1 = run1[run1.TrialType == 'Trial']
        if run2 is not None:
                run2 = run2[run2.TrialType == 'Trial']
        if run3 is not None:
                run3 = run3[run3.TrialType == 'Trial']
        # Redundant filtering removed as it is already performed earlier
        run1['Run'] = 1
        run2['Run'] = 2
        run3['Run'] = 3
        
        run1 = run1.assign(IsOwn=run1.IsOwn.eq('Yes').mul(1))  # Convert IsOwn column to 1s and 0s
        run2 = run2.assign(IsOwn=run2.IsOwn.eq('Yes').mul(1))  
        run3 = run3.assign(IsOwn=run3.IsOwn.eq('Yes').mul(1))
        
        run1 = run1.assign(GroundCueOnset=run1.GroundCueOnset.replace('Not Used', -1))
        run2 = run2.assign(GroundCueOnset=run2.GroundCueOnset.replace('Not Used', -1))
        run3 = run3.assign(GroundCueOnset=run3.GroundCueOnset.replace('Not Used', -1))

        run1.GroundCueOnset = pd.to_numeric(run1.GroundCueOnset)
        run2.GroundCueOnset = pd.to_numeric(run2.GroundCueOnset)
        run3.GroundCueOnset = pd.to_numeric(run3.GroundCueOnset)
        
        run1.CueDuration = pd.to_numeric(run1.CueDuration)
        run2.CueDuration = pd.to_numeric(run2.CueDuration)
        run3.CueDuration = pd.to_numeric(run3.CueDuration)
        
        run1.RatingOnset = pd.to_numeric(run1.RatingOnset)
        run2.RatingOnset = pd.to_numeric(run2.RatingOnset)
        run3.RatingOnset = pd.to_numeric(run3.RatingOnset)

        # only the columns we need later
        run1 = run1[['TimeAtStartOfTrial', 'CueDuration','ElaborateCueOnset', 'PostElaborateFixOnset','RatingOnset', 'RatingDuration', 'GroundCueOnset', 'GroundCueDuration','IsOwn','Run', 'GroundCueResponse', 'Rating']]
        run2 = run2[['TimeAtStartOfTrial', 'CueDuration','ElaborateCueOnset', 'PostElaborateFixOnset','RatingOnset', 'RatingDuration', 'GroundCueOnset', 'GroundCueDuration','IsOwn','Run', 'GroundCueResponse', 'Rating']]
        run3 = run3[['TimeAtStartOfTrial', 'CueDuration','ElaborateCueOnset', 'PostElaborateFixOnset','RatingOnset', 'RatingDuration', 'GroundCueOnset', 'GroundCueDuration','IsOwn','Run', 'GroundCueResponse', 'Rating']]

        # Helper function to convert milliseconds to seconds
        def convert_ms_to_s(df, columns):
            df[columns] = df[columns] / 1000
            return df

        # Columns to convert
        columns_to_convert = ['TimeAtStartOfTrial', 'CueDuration', 'ElaborateCueOnset', 'PostElaborateFixOnset', 'RatingOnset', 'RatingDuration', 'GroundCueOnset', 'GroundCueDuration']

        # Convert milliseconds to seconds for each run
        run1 = convert_ms_to_s(run1, columns_to_convert)
        run3 = convert_ms_to_s(run3, columns_to_convert)
        
        if run3 is not None:
            run3 = convert_ms_to_s(run3, columns_to_convert)
        
        # Generate outputs only for existing runs
        if run1 is not None:
            output_run1 = get_sots_all(run1, 1)
            scipy.io.savemat((d + '_run1.mat'), output_run1)
        if run2 is not None:
            output_run2 = get_sots_all(run2, 2)
            scipy.io.savemat((d + '_run2.mat'), output_run2)
        if run3 is not None:
            output_run3 = get_sots_all(run3, 3)
            scipy.io.savemat((d + '_run3.mat'), output_run3)
